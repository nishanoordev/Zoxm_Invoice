# ─────────────────────────────────────────────────────────────
# ZoxmInvoice — .gitignore
# Maintained by Antigravity | Last cleaned: 2026-04-21
# ─────────────────────────────────────────────────────────────

# ── Dependencies ─────────────────────────────────────────────
node_modules/
node_modules*/

# ── Expo / EAS ───────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── Native generated folders ─────────────────────────────────
/ios
/android
.kotlin/

# ── Native signing / certs (never commit) ────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ── Secrets & OAuth credentials ──────────────────────────────
client_secret*.json
*.secret.json
.env
.env.*
.env*.local

# ── Local database ───────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs & debug output ──────────────────────────────────────
*.log
*.orig.*
npm-debug.*
yarn-debug.*
yarn-error.*
firebase-debug.log
expo_*.log
expo_*.txt

# ── Screenshot / recording artifacts (debugging) ─────────────
*.png
*.jpg
*.jpeg
*.mp4
*.mov
*.gif

# ── Temp / experiment folders ─────────────────────────────────
temp_stitch/
zoxm_ui/
stitch_*.html

# ── Build output ─────────────────────────────────────────────
/build
/out

# ── Metro bundler ────────────────────────────────────────────
.metro-health-check*

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ── macOS ────────────────────────────────────────────────────
.DS_Store

# ── Editor ───────────────────────────────────────────────────
.vscode/settings.json
